; Outbound robot IVR with 3-way response classification
; Engine: response-classifier (see aeap.conf)
;
; SPEECH_TEXT(0) returns: positive | negative | uncertain
; uncertain -> Queue(operator) or Dial(SIP/operator)

[robot-outbound]
exten => s,1,NoOp(=== Robot outbound call ===)
 same => n,Answer()
 same => n,Set(TREE_NODE=greeting)
 same => n,Goto(robot-outbound,run,1)

exten => run,1,NoOp(Current node: ${TREE_NODE})
 same => n,GotoIf($["${TREE_NODE}" = "hangup"]?bye)
 same => n,GotoIf($["${TREE_NODE}" = "operator"]?to-operator)
 same => n,Set(PROMPT=${IF($["${TREE_NODE}" = "greeting"]?custom/greeting:${IF($["${TREE_NODE}" = "offer"]?custom/offer-details:${IF($["${TREE_NODE}" = "confirm"]?custom/thank-you:custom/goodbye)})})})
 same => n,SpeechCreate(response-classifier)
 same => n,SpeechStart()
 same => n,SpeechBackground(${PROMPT},5)
 same => n,Set(RESPONSE=${SPEECH_TEXT(0)})
 same => n,SpeechDestroy()
 same => n,NoOp(Recognized: ${RESPONSE})
 ; --- decision tree routing ---
 same => n,GotoIf($["${RESPONSE}" = "positive"]?node-positive)
 same => n,GotoIf($["${RESPONSE}" = "negative"]?node-negative)
 same => n,Goto(robot-outbound,to-operator,1)

exten => run,n(node-positive),NoOp(Positive at ${TREE_NODE})
 same => n,GotoIf($["${TREE_NODE}" = "greeting"]?set-offer)
 same => n,GotoIf($["${TREE_NODE}" = "offer"]?set-confirm)
 same => n,GotoIf($["${TREE_NODE}" = "confirm"]?bye)
 same => n,Goto(bye)

 same => n(set-offer),Set(TREE_NODE=offer)
 same => n,Goto(robot-outbound,run,1)

 same => n(set-confirm),Set(TREE_NODE=confirm)
 same => n,Goto(robot-outbound,run,1)

exten => run,n(node-negative),NoOp(Negative at ${TREE_NODE})
 same => n,GotoIf($["${TREE_NODE}" = "greeting"]?bye)
 same => n,Goto(robot-outbound,to-operator,1)

exten => to-operator,1,NoOp(Transfer to operator — uncertain or negative on confirm)
 same => n,Playback(custom/transfer-operator)
 same => n,Queue(support,t,,,120)
 same => n,Hangup()

exten => bye,1,NoOp(Goodbye)
 same => n,Playback(custom/goodbye)
 same => n,Hangup()

; Test extension
exten => 550,1,NoOp(AEAP speech test)
 same => n,Answer()
 same => n,SpeechCreate(response-classifier)
 same => n,SpeechStart()
 same => n,SpeechBackground(hello-world,5)
 same => n,Verbose(0,Result: ${SPEECH_TEXT(0)} score=${SPEECH_SCORE(0)})
 same => n,SpeechDestroy()
 same => n,Hangup()
