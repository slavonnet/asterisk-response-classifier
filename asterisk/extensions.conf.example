; Универсальный да/нет для любого диалога
; SPEECH_TEXT(0) → positive | negative | uncertain
;
; Использование в своём сценарии:
;   same => n,Gosub(yesno-ask,s,1(custom/my-question))
;   same => n,GotoIf($["${GOSUB_RETVAL}" = "positive"]?...
;   same => n,GotoIf($["${GOSUB_RETVAL}" = "negative"]?...
;   same => n,Goto(operator)    ; uncertain

[yesno-ask]
; ARG1 = sound file (без расширения)
exten => s,1,NoOp(=== Yes/No ask: ${ARG1} ===)
 same => n,SpeechCreate(response-classifier)
 same => n,SpeechStart()
 same => n,SpeechBackground(${ARG1},8)
 same => n,Set(GOSUB_RETVAL=${SPEECH_TEXT(0)})
 same => n,Verbose(0,YesNo result: ${GOSUB_RETVAL} score=${SPEECH_SCORE(0)})
 same => n,SpeechDestroy()
 same => n,Return(${GOSUB_RETVAL})

[robot-outbound]
; Пример: три вопроса подряд, uncertain → оператор
exten => s,1,Answer()
 same => n,Gosub(yesno-ask,s,1(custom/greeting))
 same => n,GotoIf($["${GOSUB_RETVAL}" = "uncertain"]?operator)
 same => n,GotoIf($["${GOSUB_RETVAL}" = "negative"]?goodbye)

 same => n,Gosub(yesno-ask,s,1(custom/offer))
 same => n,GotoIf($["${GOSUB_RETVAL}" = "uncertain"]?operator)
 same => n,GotoIf($["${GOSUB_RETVAL}" = "negative"]?goodbye)

 same => n,Gosub(yesno-ask,s,1(custom/confirm))
 same => n,GotoIf($["${GOSUB_RETVAL}" = "uncertain"]?operator)
 same => n,GotoIf($["${GOSUB_RETVAL}" = "negative"]?operator)
 same => n,Goto(thankyou)

exten => thankyou,1,Playback(custom/thank-you)
 same => n,Hangup()

exten => goodbye,1,Playback(custom/goodbye)
 same => n,Hangup()

exten => operator,1,Playback(custom/transfer-operator)
 same => n,Queue(support,t,,,120)
 same => n,Hangup()

; Тест AEAP
exten => 550,1,Answer()
 same => n,Gosub(yesno-ask,s,1(hello-world))
 same => n,Verbose(0,Test: ${GOSUB_RETVAL})
 same => n,Hangup()
