[Unit]
Description=Asterisk Response Classifier (AEAP, in-process STT)
After=network.target asterisk.service
Wants=asterisk.service

[Service]
Type=simple
User=asterisk
Group=asterisk
WorkingDirectory=INSTALL_DIR
Environment=LD_LIBRARY_PATH=INSTALL_DIR/lib
ExecStart=INSTALL_DIR/bin/arc -port 9099 -config INSTALL_DIR/config/phrases.yaml -model MODEL_DIR
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
