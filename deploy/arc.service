[Unit]
Description=Asterisk Response Classifier (audio similarity)
After=network.target asterisk.service

[Service]
Type=simple
User=asterisk
Group=asterisk
WorkingDirectory=INSTALL_DIR
ExecStart=INSTALL_DIR/arc -port 9099 -config INSTALL_DIR/config/references.yaml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
